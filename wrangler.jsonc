{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-dns-manager",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "CF_DNS_KV",
      "id": "d6e30a9c0bf8402fa975e2d582747bf4"
    }
  ]
}
